# -------------------------------------------------------------
# Enterprise HR AI Platform - Production Environment Variables
# -------------------------------------------------------------

# Gemini AI Integration
# Required for primary NLP Control Plane intent classification and response composition.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public App URL for callback redirection and domain mapping
APP_URL="MY_APP_URL"

# Production PostgreSQL Database Configurations
DB_HOST="postgres-primary.hr-platform.svc.cluster.local"
DB_PORT=5432
DB_USER="hr_admin"
DB_PASSWORD="secure_db_password_here"
DB_NAME="hr_production"
DB_POOL_MAX=20

# Durable Orchestration (Temporal Cloud / Self-hosted Cluster)
TEMPORAL_ADDRESS="temporal-frontend.temporal.svc.cluster.local:7233"
TEMPORAL_NAMESPACE="hr-workflows"

# Event Bus & Streaming Platform (Apache Kafka Cluster)
KAFKA_BOOTSTRAP_SERVERS="kafka-broker-1.kafka.svc.cluster.local:9092,kafka-broker-2.kafka.svc.cluster.local:9092"
KAFKA_CLIENT_ID="hr-ai-control-plane"
KAFKA_CONSUMER_GROUP="hr-compliance-evaluators"

# Vector Embedding Database (Qdrant Cloud / Cluster)
QDRANT_URL="https://qdrant-cluster.hr-platform.svc.cluster.local:6334"
QDRANT_API_KEY="secure_qdrant_api_key_here"

# Fast-Access Session & Cache Plane (Redis Cluster)
REDIS_HOST="redis-sentinel.cache.svc.cluster.local"
REDIS_PORT=6379
REDIS_PASSWORD="secure_redis_password_here"

# Security & Compliance Auditing
ENCRYPTION_SECRET_KEY="aes-256-gcm-master-secret-key"
compliance_security_audit_topic="compliance.security.audit"
